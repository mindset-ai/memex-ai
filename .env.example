# Repo-root .env — secrets SHARED across packages for local development.
# Loaded by both the server and admin vitest suites (see packages/server/vitest.setup.ts
# and packages/ui/src/test/setup.ts). Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#
# Your `.env` is gitignored on every workstation (see .gitignore). Never commit real keys.
# In CI these are job-level env vars / secrets, NOT a committed file.

# ── AC emission (spec-129) ────────────────────────────────────────────────────
# A per-Memex emission key authorises POSTs to /api/test-events, so tests that call
# tagAc('<ns>/<memex>/specs/spec-N/acs/ac-M') verify their ACs on that Memex. Without
# a valid key, emissions are rejected 401 and silently dropped (ac-16) — tests still
# pass, but no AC verifies.
#
# Mint one in the Memex UI: open the Memex your tests' ac_uids name (e.g.
# mindset-prod/memex-building-itself) → your account menu → "Memex keys" → generate.
# Any member can mint (not just admins). A key only authorises ITS OWN Memex.
MEMEX_EMIT_KEY=

# Set MEMEX_EMIT=off to disable emission locally (default is on).
# MEMEX_EMIT=off
