node_modules/
dist/
# Secrets / local env. The bare `.env` (no leading slash) matches at EVERY depth,
# so the repo-root shared-secret .env (MEMEX_EMIT_KEY etc.) AND each package's
# .env (packages/*/.env) are all ignored — on every workstation, because this
# file is committed and travels with every clone. Committed templates only:
# .env.example (root) and packages/server/.env.example.
.env
.env.local

# Per-environment deploy config — instance-specific values (project ids, hosts,
# buckets, client ids). Committed template: scripts/deploy.env.example
scripts/deploy.*.env
*.tgz
.DS_Store
.logs/
tmp/
.doc-20-state.md

# Test/coverage artefacts — regenerated by vitest/playwright on every run.
coverage/
test-results/

# Claude Code workspace state — agent worktrees, scheduled-task locks,
# transcript caches. Nothing in here belongs in the repo.
.claude/

# Internal-only docs (runbooks, migration/launch records, planning artifacts).
# Kept on disk for reference; excluded from the repo and the public export.
_private/

# TypeScript incremental compile cache — produced by `tsc` when
# `--incremental` is on (default for some configs). Per-machine artefact.
*.tsbuildinfo
