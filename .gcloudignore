# Files excluded from `gcloud builds submit` upload. Keeps the server build
# context lean — admin/cli/extractor are deployed separately and aren't part
# of the server image.

.git
.github
.claude
.vscode
.idea
.DS_Store

node_modules
**/node_modules

dist
**/dist
**/.vitest-cache
**/coverage

.env
.env.*
*.log
**/.logs

# Other workspace packages aren't needed for the server image.
packages/ui
packages/cli
packages/extractor

# Misc
docs
blueprint
*.md
!packages/server/src/agent/skills/*.md
!packages/server/src/agent/phases/**/*.md
# spec-190: the voice guide's system prompt is a runtime-loaded markdown asset
# (std-15), copied into the image by the server build. Without this negation the
# *.md rule above strips it from the Cloud Build context → `cp src/agent/voice/*.md`
# fails and the image build dies.
!packages/server/src/agent/voice/*.md
