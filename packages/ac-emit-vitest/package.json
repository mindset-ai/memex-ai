{
  "name": "@memex-ai-ac/vitest",
  "version": "0.1.3",
  "description": "Acceptance Criteria emit helper for Vitest. Tag tests with tagAc(), emit pass/fail to a Memex workspace.",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://memex.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/mindset-ai/memex-app",
    "directory": "packages/ac-emit-vitest"
  },
  "keywords": [
    "memex",
    "acceptance-criteria",
    "vitest",
    "test-tracking",
    "memex-ai"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./setup": {
      "development": "./src/setup.ts",
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "rm -rf dist && pnpm run build"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "typescript": "^5.7.0",
    "vitest": "4.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./setup": {
        "types": "./dist/setup.d.ts",
        "default": "./dist/setup.js"
      }
    }
  }
}
