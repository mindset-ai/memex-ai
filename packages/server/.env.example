# ============================================================
# LOCAL DEVELOPMENT ONLY
# ============================================================
# IMPORTANT: All development MUST use a local PostgreSQL instance.
# NEVER connect to the hosted/production Cloud SQL database
# during development. The production database is managed
# exclusively via deploy.sh.
#
# Start local Postgres:  brew services start postgresql@16
# Stop local Postgres:   brew services stop postgresql@16
# ============================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memex
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
