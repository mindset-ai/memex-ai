{
  "name": "@memex/server",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db/connection": "./src/db/connection.ts",
    "./db/schema": "./src/db/schema.ts",
    "./services/repos": "./src/services/repos.ts",
    "./services/files": "./src/services/files.ts",
    "./services/symbols": "./src/services/symbols.ts",
    "./services/imports": "./src/services/imports.ts",
    "./services/calls": "./src/services/calls.ts",
    "./services/endpoints": "./src/services/endpoints.ts",
    "./services/repo-meta": "./src/services/repo-meta.ts",
    "./services/ingestion": "./src/services/ingestion.ts",
    "./services/embeddings": "./src/services/embeddings.ts",
    "./services/embedding-provider": "./src/services/embedding-provider.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @memex/shared build",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/agent/skills && cp src/agent/skills/*.md dist/agent/skills/ && mkdir -p dist/agent/phases && cp -R src/agent/phases/. dist/agent/phases/ && find dist/agent/phases -name '*.ORPHAN' -delete && mkdir -p dist/guidance && cp src/guidance/*.json dist/guidance/",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && bash scripts/apply-hand-migrations.sh",
    "db:migrate:journal": "drizzle-kit migrate",
    "db:migrate:hand": "bash scripts/apply-hand-migrations.sh",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-reviewer": "tsx src/db/seed-reviewer.ts",
    "db:seed-smoke": "tsx src/db/seed-smoke.ts",
    "db:backfill-handhold": "tsx scripts/backfill-handhold-demo.ts",
    "db:backfill-default-standards": "tsx scripts/backfill-default-standards.ts",
    "oauth:smoke": "node scripts/oauth-smoke.mjs",
    "docker:build": "docker build -t memex-server .",
    "docker:run": "docker run -p 8080:8080 --env-file .env memex-server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts' --exclude '**/*.api.test.ts' --exclude '**/*.security.test.ts' --exclude '**/*.perf.test.ts' --exclude '**/*.regression.test.ts' --exclude '**/*.smoke.test.ts'",
    "test:integration": "vitest run integration.test",
    "test:api": "vitest run api.test",
    "test:security": "vitest run src/__security__",
    "test:perf": "vitest run src/__perf__",
    "test:regression": "vitest run src/__regression__",
    "test:coverage": "vitest run --coverage",
    "notify:mcp-refs": "tsx scripts/notify-mcp-canonical-refs.ts",
    "smoke:canonical-refs": "tsx scripts/smoke-canonical-refs.ts",
    "smoke": "vitest run --config vitest.smoke.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-cloud/kms": "^5.5.0",
    "@hono/node-server": "^1.13.0",
    "@memex/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/web-api": "^7.16.0",
    "cohere-ai": "^7.21.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.0",
    "google-auth-library": "^10.6.2",
    "hono": "^4.7.0",
    "openai": "^4.104.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@memex-ai-ac/vitest": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
